# ─── Auth Mode ───────────────────────────────────────────────
# "mock"  → local mock login (default, no backend required)
# "api"   → real backend login via VITE_API_BASE_URL
VITE_AUTH_MODE=mock

# ─── Backend Base URL ────────────────────────────────────────
# All Axios requests are prefixed with this URL.
# Auth:  POST  /auth/login
# Leads: GET   /leads
#        POST  /leads
#        GET   /leads/:id
#        PUT   /leads/:id
#        DELETE /leads/:id
VITE_API_BASE_URL=https://trakv-ehuq.onrender.com/api
